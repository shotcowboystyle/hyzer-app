/* Push notification alert body for "Round Started" (Story 12.1, AC #1).
   %1$@ = organizer first name, %2$@ = course name.
   CloudKit substitutes field values server-side via alertLocalizationArgs.
   Positional specifiers allow translators in future locales to reorder arguments
   (e.g., languages where the course name precedes the verb). */
"ROUND_STARTED_FORMAT" = "%1$@ started a round at %2$@";

/* Push notification alert body for "Round Complete" (Story 12.2, AC #1).
   %1$@ = course name, %2$@ = winner first name, %3$@ = winner score display ("+2"/"-3"/"E").
   Positional specifiers allow translators in future locales to reorder arguments. */
"ROUND_COMPLETE_FORMAT" = "Round complete at %1$@. %2$@ won at %3$@.";

/* Push notification alert body for "Discrepancy Detected" (Story 12.3, AC #1, #5).
   %1$@ = hole number (CloudKit substitutes the integer via alertLocalizationArgs).
   PII gate: NO player name, NO course name, NO stroke counts in the alert body.
   Positional specifier preserved for future translator flexibility (matches 12.1/12.2). */
"DISCREPANCY_DETECTED_FORMAT" = "Score discrepancy on hole %1$@ needs review.";

/* Banner shown above the discrepancy resolution view when the discrepancy has
   already been resolved (Story 12.3, AC #4). Both display text and accessibility
   label are localized; future translators can reorder freely. */
"DISCREPANCY_ALREADY_RESOLVED_BANNER" = "Already resolved — read-only";
"DISCREPANCY_ALREADY_RESOLVED_BANNER_A11Y" = "This discrepancy has already been resolved and is shown in read-only mode.";
