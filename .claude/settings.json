{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {},
  "enabledPlugins": {
    "voltagent-lang@voltagent-subagents": true
  },
  "permissions": {
    "allow": [
      "Read(*)",
      "Write(*)",
      "Edit(*)",
      "MultiEdit(*)",
      "Bash(swift *)",
      "Bash(xcodebuild *)",
      "Bash(xcodegen *)",
      "Bash(xcrun *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git rev-parse *)",
      "Bash(git status*)",
      "Bash(git worktree *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(plutil *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(ls *)",
      "Bash(swiftlint *)",
      "Bash(shasum *)",
      "Bash(cmp *)",
      "Bash(python3 *)",
      "Bash(tee *)",
      "Bash(echo *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(sort *)",
      "Bash(uniq *)",
      "Bash(rm *)",
      "Bash(touch *)",
      "Bash(sed *)",
      "Bash(awk *)",
      "Bash(open *)",
      "Bash(xcrun simctl *)"
    ],
    "deny": []
  }
}
